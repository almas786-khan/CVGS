@model CVGS.Models.Game

@{
    ViewBag.Title = "Details";
}

<h2>Details</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.GameName)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.GameName)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.GameDescription)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.GameDescription)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.GamePrice)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.GamePrice)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.GameOverallRating)
        </dt>

        <dd>
            @for (int i = 0; i < @Model.GameOverallRating; i++)
            {
                <span class="glyphicon glyphicon-star"></span>
            }
            @for (var i = @Model.GameOverallRating; i < 5; i++)
            {
                <span class="glyphicon glyphicon-star-empty"></span>
            }

            @*@Html.DisplayFor(model => model.GameOverallRating)*@
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Rate","Rate","Rating")
    @Html.ActionLink("Back to List", "Index", "Member")
</p>


