@model IEnumerable<CVGS.Models.User>
@{
    ViewBag.Title = "AddFriend";
}

<h2>Add Friends</h2>

<br />


@using (Html.BeginForm("AddFriend", "Friend", FormMethod.Get))

{
    @Html.TextBox("Search", null, new { Class = "form-control", placeHolder = "Search Your Friends Here" })
    <input type="submit" value="Search" class="btn btn-success" />
    @*<a class="btn btn-success" onclick="SaveList()">Details</a>*@
}
<table class="table table-striped" id="ItemList">
    <thead>
        <tr>
            <th></th>
            <th>
                @Html.DisplayNameFor(model => model.UserName)
            </th>

            <th>

            </th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count() == 0)
        {
            <tr>
                <td style="color:red" colspan="3">
                    No Friend Found.
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>
                        <ul>
                            <li>
                                @*<a href="@Url.Action("Details", "Member")" new { id=item.GameID }> @Html.DisplayFor(modelItem => item.GameName)</a>*@
                                <a href='/Friend/Details/@item.UserID'> @Html.DisplayFor(modelItem => item.UserName)</a>
                            </li>
                        </ul>

                    </td>

                   

                </tr>
            }
        }

    </tbody>
</table>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>

}


